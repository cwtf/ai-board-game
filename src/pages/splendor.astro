---
import Header from '@/components/shell/Header.svelte';
import SplendorGame from '@/components/games/splendor/SplendorGame.svelte';
import SEO from '@/components/shell/SEO.astro';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <SEO
      title="Splendor AI Game | AI Board Game Platform"
      description="Play Splendor against configurable AI opponents in a browser-based local-first board game table."
      path="/splendor"
    />
  </head>
  <body class="flex h-screen flex-col overflow-hidden bg-neutral-950 text-neutral-100">
    <Header client:load backHref="/" />
    <main class="min-h-0 flex-1 overflow-hidden">
      <SplendorGame client:load />
    </main>
  </body>
</html>
