---
import SecretHitlerGame from '@/components/games/secret-hitler/SecretHitlerGame.svelte';
import Header from '@/components/shell/Header.svelte';
import SEO from '@/components/shell/SEO.astro';
import { absoluteSiteUrl, siteUrl } from '@/lib/site';
import '../styles/global.css';

const baseUrl = siteUrl();
const pageDescription =
  'Play a local-first Secret Hitler-inspired social deduction table with configurable AI players, hidden roles, policy decks, and table chat.';
const pageImage = '/screenshots/secret-hitler.png';
const secretHitlerJsonLd = {
  '@type': 'VideoGame',
  '@id': `${absoluteSiteUrl('/secret-hitler', baseUrl)}#game`,
  name: 'Secret Hitler AI Game',
  url: absoluteSiteUrl('/secret-hitler', baseUrl),
  description: pageDescription,
  image: absoluteSiteUrl(pageImage, baseUrl),
  gamePlatform: 'Web browser',
  applicationCategory: 'Game',
  operatingSystem: 'Web',
  numberOfPlayers: {
    '@type': 'QuantitativeValue',
    minValue: 5,
    maxValue: 10,
  },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<html lang="en">
  <head>
    <SEO
      title="Secret Hitler AI Game | AI Board Game Platform"
      description={pageDescription}
      path="/secret-hitler"
      image={pageImage}
      imageAlt="Secret Hitler AI game table screenshot"
      jsonLd={secretHitlerJsonLd}
    />
  </head>
  <body class="flex h-screen flex-col overflow-hidden bg-neutral-950 text-neutral-100">
    <Header client:load backHref="/" />
    <main class="min-h-0 flex-1 overflow-hidden">
      <SecretHitlerGame client:load />
    </main>
  </body>
</html>
