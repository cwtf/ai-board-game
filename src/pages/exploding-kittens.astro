---
import Header from '@/components/shell/Header.svelte';
import SEO from '@/components/shell/SEO.astro';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <SEO
      title="Exploding Kittens AI Game | AI Board Game Platform"
      description="Preview the upcoming Exploding Kittens route for the local-first AI Board Game Platform."
      path="/exploding-kittens"
    />
  </head>
  <body class="min-h-screen bg-neutral-950 text-neutral-100">
    <Header client:load />
    <main class="mx-auto max-w-4xl px-6 py-16">
      <p class="text-sm font-medium uppercase tracking-wide text-emerald-300">
        Coming in Phase 8
      </p>
      <h1 class="mt-4 text-4xl font-semibold tracking-normal">
        Exploding Kittens
      </h1>
      <p class="mt-4 max-w-2xl text-neutral-300">
        The game route is ready. The hidden-information engine and table UI will
        land in the upcoming engine and UI phases.
      </p>
      <a
        class="mt-6 inline-flex rounded-md border border-neutral-700 px-4 py-2 text-sm text-neutral-200 hover:border-neutral-500"
        href="/docs/games/exploding-kittens.md"
        target="_blank"
        rel="noreferrer"
      >
        View rules
      </a>
    </main>
  </body>
</html>
