---
import Header from '@/components/shell/Header.svelte';
import SEO from '@/components/shell/SEO.astro';
import { absoluteSiteUrl, siteUrl } from '@/lib/site';
import '../styles/global.css';

const baseUrl = siteUrl();
const pageDescription =
  'Preview the upcoming Exploding Kittens route for the local-first AI Board Game Platform.';
const explodingKittensJsonLd = {
  '@type': 'VideoGame',
  '@id': `${absoluteSiteUrl('/exploding-kittens', baseUrl)}#game`,
  name: 'Exploding Kittens AI Game',
  url: absoluteSiteUrl('/exploding-kittens', baseUrl),
  description: pageDescription,
  gamePlatform: 'Web browser',
  applicationCategory: 'Game',
  operatingSystem: 'Web',
  numberOfPlayers: {
    '@type': 'QuantitativeValue',
    minValue: 2,
    maxValue: 5,
  },
};
---

<html lang="en">
  <head>
    <SEO
      title="Exploding Kittens AI Game | AI Board Game Platform"
      description={pageDescription}
      path="/exploding-kittens"
      image="/screenshots/secret-hitler.png"
      imageAlt="AI Board Games browser table screenshot"
      jsonLd={explodingKittensJsonLd}
    />
  </head>
  <body class="min-h-screen bg-neutral-950 text-neutral-100">
    <Header client:load />
    <main class="mx-auto max-w-4xl px-6 py-16">
      <p class="text-sm font-medium uppercase tracking-wide text-emerald-300">
        Coming in Phase 8
      </p>
      <h1 class="mt-4 text-4xl font-semibold tracking-normal">
        Exploding Kittens
      </h1>
      <p class="mt-4 max-w-2xl text-neutral-300">
        The game route is ready. The hidden-information engine and table UI will
        land in the upcoming engine and UI phases.
      </p>
      <a
        class="mt-6 inline-flex rounded-md border border-neutral-700 px-4 py-2 text-sm text-neutral-200 hover:border-neutral-500"
        href="/docs/games/exploding-kittens.md"
        target="_blank"
        rel="noreferrer"
      >
        View rules
      </a>
    </main>
  </body>
</html>
