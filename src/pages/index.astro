---
import GameGrid from '@/components/games/GameGrid.svelte';
import Header from '@/components/shell/Header.svelte';
import SEO from '@/components/shell/SEO.astro';
import { absoluteSiteUrl, siteUrl } from '@/lib/site';
import '../styles/global.css';

const baseUrl = siteUrl();
const pageDescription =
  'Play local-first board games against configurable AI opponents with bring-your-own-key provider settings.';
const pageImage = '/screenshots/secret-hitler.png';
const homeJsonLd = [
  {
    '@type': 'WebSite',
    '@id': `${baseUrl}/#website`,
    name: 'AI Board Games',
    url: baseUrl,
    description: pageDescription,
  },
  {
    '@type': 'SoftwareApplication',
    '@id': `${baseUrl}/#app`,
    name: 'AI Board Games',
    applicationCategory: 'GameApplication',
    operatingSystem: 'Web',
    url: baseUrl,
    description: pageDescription,
    image: absoluteSiteUrl(pageImage, baseUrl),
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
  },
];
---

<html lang="en">
  <head>
    <SEO
      title="AI Board Game Platform | Local AI Tabletop Games"
      description={pageDescription}
      path="/"
      image={pageImage}
      imageAlt="Secret Hitler game table screenshot from AI Board Games"
      jsonLd={homeJsonLd}
    />
  </head>
  <body class="bg-neutral-950 text-neutral-100">
    <Header client:load />
    <main class="mx-auto min-h-screen max-w-6xl px-6 py-12">
      <section class="border-b border-neutral-800 pb-10">
        <p class="text-sm font-medium uppercase tracking-wide text-emerald-300">
          Local-first BYOK
        </p>
        <h1
          class="mt-4 max-w-3xl text-4xl font-semibold tracking-normal sm:text-6xl"
        >
          Play board games against the AI you bring.
        </h1>
        <p class="mt-6 max-w-2xl text-lg text-neutral-300">
          Pick a game and start playing locally. Configure a provider when you
          want AI seats to take turns; your API key stays in your own browser.
        </p>
        <div class="mt-6 flex flex-wrap gap-3 text-sm">
          <a
            class="rounded-md bg-emerald-500 px-4 py-2 font-medium text-neutral-950 hover:bg-emerald-400"
            href="/settings"
          >
            Configure provider
          </a>
          <a
            class="rounded-md border border-neutral-700 px-4 py-2 text-neutral-200 hover:border-neutral-500"
            href="/about"
          >
            About
          </a>
        </div>
      </section>

      <section class="py-10">
        <div class="mb-5 flex items-end justify-between gap-4">
          <div>
            <h2 class="text-2xl font-semibold tracking-normal">Games</h2>
            <p class="mt-2 text-sm text-neutral-400">
              Play now, then add model profiles from settings whenever you want AI opponents.
            </p>
          </div>
        </div>
        <GameGrid client:load />
      </section>
    </main>
    <footer
      class="border-t border-neutral-800 px-6 py-6 text-sm text-neutral-500"
    >
      <div class="mx-auto flex max-w-6xl flex-wrap gap-4">
        <a class="hover:text-neutral-300" href="/settings">Settings</a>
        <a
          class="hover:text-neutral-300"
          href="/docs/TODO.md"
          target="_blank"
          rel="noreferrer"
        >
          Roadmap
        </a>
        <span>v0.0.1</span>
      </div>
    </footer>
  </body>
</html>
