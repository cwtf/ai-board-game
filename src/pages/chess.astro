---
import ChessGame from '@/components/games/chess/ChessGame.svelte';
import Header from '@/components/shell/Header.svelte';
import SEO from '@/components/shell/SEO.astro';
import { createGameJsonLd, gameSeoById } from '@/lib/seo';
import { siteUrl } from '@/lib/site';
import '../styles/global.css';

const baseUrl = siteUrl();
const pageSeo = gameSeoById.chess;
const chessJsonLd = createGameJsonLd(pageSeo, baseUrl);
---

<html lang="en">
  <head>
    <SEO
      title={pageSeo.title}
      description={pageSeo.description}
      path={pageSeo.path}
      image={pageSeo.image}
      imageAlt={pageSeo.imageAlt}
      keywords={pageSeo.keywords}
      jsonLd={chessJsonLd}
    />
  </head>
  <body
    class="flex h-screen flex-col overflow-hidden bg-neutral-950 text-neutral-100"
  >
    <Header client:load backHref="/" />
    <main class="min-h-0 flex-1 overflow-hidden">
      <ChessGame client:load />
    </main>
  </body>
</html>
