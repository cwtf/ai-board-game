---
interface Props {
  title: string;
  description: string;
  path?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  image?: string;
  imageAlt?: string;
  keywords?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

import { absoluteSiteUrl, siteUrl as getSiteUrl } from '@/lib/site';
import {
  DEFAULT_SEO_IMAGE,
  DEFAULT_SEO_IMAGE_ALT,
  SITE_NAME,
  imageSizeFor,
} from '@/lib/seo';

const {
  title,
  description,
  path = '/',
  noindex = false,
  type = 'website',
  image = DEFAULT_SEO_IMAGE,
  imageAlt = DEFAULT_SEO_IMAGE_ALT,
  keywords = [],
  jsonLd,
} = Astro.props;
const siteUrl = getSiteUrl();
const canonicalUrl = absoluteSiteUrl(path, siteUrl);
const imageUrl = absoluteSiteUrl(image, siteUrl);
const imageSize = imageSizeFor(image);
const robots = noindex
  ? 'noindex, nofollow'
  : 'index, follow, max-image-preview:large';
const baseJsonLd = {
  '@type': 'WebPage',
  '@id': `${canonicalUrl}#webpage`,
  url: canonicalUrl,
  name: title,
  description,
  inLanguage: 'en',
  image: imageUrl,
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: imageUrl,
    width: imageSize?.width,
    height: imageSize?.height,
    caption: imageAlt,
  },
  isPartOf: {
    '@type': 'WebSite',
    '@id': `${siteUrl}/#website`,
    name: SITE_NAME,
    url: siteUrl,
  },
};
const extraJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const structuredData = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [baseJsonLd, ...extraJsonLd],
});
---

<meta charset="utf-8" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<meta name="viewport" content="width=device-width" />
<meta name="application-name" content={SITE_NAME} />
<meta name="theme-color" content="#0a0a0a" />
<meta name="color-scheme" content="dark" />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>
<meta name="description" content={description} />
{
  keywords.length ? (
    <meta name="keywords" content={keywords.join(', ')} />
  ) : null
}
<link rel="canonical" href={canonicalUrl} />
<meta name="robots" content={robots} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:locale" content="en_US" />
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:alt" content={imageAlt} />
{
  imageSize ? (
    <>
      <meta property="og:image:width" content={String(imageSize.width)} />
      <meta property="og:image:height" content={String(imageSize.height)} />
    </>
  ) : null
}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={imageAlt} />
<script is:inline type="application/ld+json" set:html={structuredData} />
